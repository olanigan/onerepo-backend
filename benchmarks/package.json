{
  "name": "@onecoder/benchmarks",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "benchmark:all": "tsx runner/benchmark.ts --all",
    "benchmark:cpu-bound": "tsx runner/benchmark.ts --scenario=cpu-bound",
    "benchmark:io-heavy": "tsx runner/benchmark.ts --scenario=io-heavy",
    "benchmark:memory": "tsx runner/benchmark.ts --scenario=memory",
    "benchmark:cascading": "tsx runner/benchmark.ts --scenario=cascading",
    "benchmark:malicious": "tsx runner/benchmark.ts --scenario=malicious",
    "generate-report": "tsx runner/report.ts",
    "watch": "nodemon --exec npm run benchmark:all"
  },
  "dependencies": {
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "nodemon": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
